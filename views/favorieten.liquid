{% render 'partials/head.liquid' %}
{% render 'partials/header.liquid' %}

<main class="favorites-page">
    <div class="favorites-container">

        <nav class="breadcrumb">
            <a href="/">
                <img
                    src="/style/assets/house@2x.svg"
                    alt=""
                    class="icon"
                    width="24"
                    height="24"
                >
            </a>

            <span>/</span>
            <span>Mijn account</span>
            <span>/</span>
            <span>Favorieten</span>
        </nav>

        <h1 class="page-title">{{ title }}</h1>

        {% if houses.size == 0 %}

            <section class="empty-state">
                <img
                    src="/style/assets/heart@2x.svg"
                    alt=""
                    class="empty-icon"
                    width="72"
                    height="72"
                >

                <h2>Tip: bewaar een huis</h2>

                <p>
                    Tik op het hart-icoon bij je favoriete huis om deze toe te voegen aan je favorieten.
                </p>

                <a href="/" class="search-button">
                    Start met zoeken
                </a>
            </section>

        {% else %}

            <section class="houses-grid">
                {% for house in houses %}
                    <article class="house-card">
                        <a href="/huis-detail/{{ house.id }}">
                            <img
                                class="house-card-image"
                                src="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?width=600"
                                alt=""
                                loading="lazy"
                                width="600"
                                height="400"
                            >

                            <div class="house-card-content">
                                <h2>
                                    {{ house.street }}
                                    {{ house.house_nr }}
                                    {{ house.nr_addition }}
                                </h2>

                                <p>
                                    {{ house.postal_code }}
                                    {{ house.city }}
                                </p>

                                <strong>
                                    € {{ house.priceFormatted | default: house.price }}
                                </strong>

                                <dl class="house-features">
                                    <div>
                                        <dt>Kamers</dt>
                                        <dd>
                                            <img
                                                src="/style/assets/bed@2x.svg"
                                                alt=""
                                                class="icon"
                                                width="18"
                                                height="18"
                                            >
                                            {{ house.rooms }} kamers
                                        </dd>
                                    </div>

                                    <div>
                                        <dt>Oppervlakte</dt>
                                        <dd>
                                            <img
                                                src="/style/assets/icons/area.svg"
                                                alt=""
                                                class="icon"
                                                width="18"
                                                height="18"
                                            >
                                            {{ house.m2 }} m²
                                        </dd>
                                    </div>
                                </dl>
                            </div>
                        </a>
                    </article>
                {% endfor %}
            </section>

        {% endif %}

    </div>
</main>

{% render 'partials/footer.liquid' %}