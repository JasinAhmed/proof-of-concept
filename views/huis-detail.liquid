{% render 'partials/head.liquid' %}
{% render 'partials/header.liquid' %}

<main>

  <nav class="breadcrumb">
    <a href="/" aria-label="Home">
      <img src="/style/assets/house@2x.svg" alt="">
    </a>

    <span>/</span>
    <a href="#">{{ house.city }}</a>
    <span>/</span>
    <a href="#">{{ house.city }} Plassengebied</a>
    <span>/</span>
    <span>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</span>
  </nav>

  <div class="main-image">
    <img
      class="primary-image"
      src="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?width=1400"
      alt="{{ house.street }}"
    >

    {% for image in house.gallery limit:4 %}
      <img
        class="secondary-image"
        src="https://fdnd-agency.directus.app/assets/{{ image.directus_files_id }}?width=900"
        alt="Foto van {{ house.street }}"
      >
    {% endfor %}

    <div class="gallery-actions">
      <button type="button" class="share-button">
        <img src="/style/assets/share@2x.svg" alt="">
        <span>Delen</span>
      </button>

      <form action="/favorieten/{{ house.id }}" method="POST" class="favorite-form" data-house-id="{{ house.id }}">
        <button type="submit" class="favorite-button" id="favoriteButton">
          <span class="favorite-heart" aria-hidden="true">♡</span>
          <span class="favorite-text">Bewaren</span>
        </button>
      </form>
    </div>
  </div>

  <div class="media-options">
    <ul>
      <li>
        <a href="#">
          <img src="/style/assets/images@2x.svg" alt="">
          <span>Foto's</span>
          <small>{{ house.gallery | size | plus: 1 }}</small>
        </a>
      </li>

      <li>
        <a href="#">
          <img src="/style/assets/floorplan@2x.svg" alt="">
          <span>Plattegrond</span>
          <small>7</small>
        </a>
      </li>

      <li>
        <a href="#">
          <img src="/style/assets/video@2x.svg" alt="">
          <span>Video</span>
        </a>
      </li>

      <li>
        <a href="#">
          <img src="/style/assets/overview@2x.svg" alt="">
          <span>Alle media</span>
        </a>
      </li>
    </ul>
  </div>

  <section class="main-info">
    <h1>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</h1>

    <div class="zip-code-wrapper">
      <p class="zip-code">{{ house.postal_code }} {{ house.city }}</p>
      <a href="#">{{ house.city }} Plassengebied</a>
    </div>

    <p class="price">€ {{ house.price }} k.k.</p>

    <dl class="main-info-list">
      <div>
        <dt>Wonen</dt>
        <dd>{{ house.m2 }} m²</dd>
      </div>

      <div>
        <dt>Perceel</dt>
        <dd>{{ house.m2_garden }} m²</dd>
      </div>

      <div>
        <dt>Kamers</dt>
        <dd>{{ house.rooms }}</dd>
      </div>
    </dl>
  </section>

  <div class="detail-layout">

    <div class="detail-content">

      <section class="description">
        <h2>Omschrijving</h2>

        <div class="description-text">
          {{ house.description }}
        </div>
      </section>

      <section class="features">
        <h2>Kenmerken</h2>

        <section>
          <h3>Overdracht</h3>

          <dl>
            <dt>Aangeboden sinds</dt>
            <dd>{{ house.listed_date | default: "Niet beschikbaar" }}</dd>

            <dt>Aanvaarding</dt>
            <dd>In overleg</dd>

            <dt>Vraagprijs</dt>
            <dd>€ {{ house.price }} kosten koper</dd>

            <dt>Status</dt>
            <dd>{{ house.status | default: "Beschikbaar" }}</dd>
          </dl>
        </section>

        <section>
          <h3>Bouw</h3>

          <dl>
            <dt>Soort woonhuis</dt>
            <dd>{{ house.type | default: "Villa, vrijstaande woning" }}</dd>

            <dt>Soort bouw</dt>
            <dd>Bestaande bouw</dd>

            <dt>Bouwjaar</dt>
            <dd>{{ house.build_year | default: "Niet beschikbaar" }}</dd>

            <dt>Soort dak</dt>
            <dd>{{ house.roof_type | default: "Niet beschikbaar" }}</dd>
          </dl>
        </section>

        <section>
          <h3>Oppervlakten en inhoud</h3>

          <dl>
            <dt>Wonen</dt>
            <dd>{{ house.m2 }} m²</dd>

            <dt>Perceel</dt>
            <dd>{{ house.m2_garden }} m²</dd>

            <dt>Inhoud</dt>
            <dd>{{ house.volume | default: "Niet beschikbaar" }}</dd>
          </dl>
        </section>

        <section>
          <h3>Indeling</h3>

          <dl>
            <dt>Aantal kamers</dt>
            <dd>{{ house.rooms }} kamers</dd>

            <dt>Aantal slaapkamers</dt>
            <dd>{{ house.bedrooms | default: "Niet beschikbaar" }}</dd>

            <dt>Aantal badkamers</dt>
            <dd>{{ house.bathrooms | default: "Niet beschikbaar" }}</dd>

            <dt>Aantal woonlagen</dt>
            <dd>{{ house.floors | default: "Niet beschikbaar" }}</dd>
          </dl>
        </section>

        <section>
          <h3>Energie</h3>

          <dl>
            <dt>Energielabel</dt>
            <dd>{{ house.energy_label | default: "Niet beschikbaar" }}</dd>

            <dt>Isolatie</dt>
            <dd>{{ house.insulation | default: "Niet beschikbaar" }}</dd>

            <dt>Verwarming</dt>
            <dd>{{ house.heating | default: "Niet beschikbaar" }}</dd>
          </dl>
        </section>

        <section>
          <h3>Kadastrale gegevens</h3>

          <dl>
            <dt>Kadastrale gemeente</dt>
            <dd>{{ house.city | default: "Niet beschikbaar" }}</dd>

            <dt>Oppervlakte</dt>
            <dd>{{ house.m2_garden | default: "Niet beschikbaar" }} m²</dd>

            <dt>Eigendomssituatie</dt>
            <dd>{{ house.ownership | default: "Volle eigendom" }}</dd>
          </dl>
        </section>
      </section>

      <section class="popularity">
        <h2>Populariteit</h2>

        <div class="popularity-card">
          <div class="popularity-item">
            <img src="/style/assets/eye@2x.svg" alt="">
            <strong>{{ house.views | default: "227.286x" }}</strong>
            <span>Bekeken</span>
          </div>

          <div class="popularity-item">
            <img src="/style/assets/heart@2x.svg" alt="">
            <strong>{{ house.saved_count | default: "1.900x" }}</strong>
            <span>Bewaard</span>
          </div>

          <div class="popularity-item">
            <img src="/style/assets/calendar@2x.svg" alt="">
            <strong>{{ house.listed_date | default: "Niet beschikbaar" }}</strong>
            <span>Op Funda</span>
          </div>
        </div>
      </section>

      <section class="neighborhood">
        <h2>Buurt</h2>

        <div class="neighborhood-layout">
          <article class="neighborhood-card">
            <div class="neighborhood-header">
              <img src="/style/assets/map@2x.svg" alt="">

              <div>
                <h3>{{ house.city }} Plassengebied</h3>
                <p>{{ house.city }}</p>
              </div>
            </div>

            <dl>
              <dt>Inwoners</dt>
              <dd>{{ house.population | default: "Niet beschikbaar" }}</dd>

              <dt>Gezin met kinderen</dt>
              <dd>{{ house.families_with_children | default: "Niet beschikbaar" }}</dd>

              <dt>Gemiddelde leeftijd</dt>
              <dd>{{ house.average_age | default: "Niet beschikbaar" }}</dd>

              <dt>Woningen in de buurt</dt>
              <dd>{{ house.neighborhood_houses | default: "Niet beschikbaar" }}</dd>
            </dl>
          </article>

          <aside class="discover-neighborhood">
            <h3>Ontdek de buurt</h3>
            <p>Benieuwd naar het woningaanbod, bewoners en lokale makelaars?</p>
          </aside>
        </div>
      </section>

    </div>

    <aside class="broker-card">
      <div class="broker-card-top"></div>

      <div class="broker-card-content">
        <img
          class="broker-logo"
          src="/style/assets/Logo.svg"
          alt="{{ house.agent }}"
        >

        <h2>{{ house.agent | default: "The Agency The Netherlands" }}</h2>

        <a href="tel:{{ house.agent_phone }}" class="broker-phone">
          <span>📞</span>
          <span>Toon telefoonnummer</span>
        </a>
      </div>

      <div class="broker-card-actions">
        <a href="#" class="broker-contact-button">
          <span>✉</span>
          <span>Neem contact op</span>
        </a>

        <a href="#" class="broker-viewing-button">
          <span>📅</span>
          <span>Vraag bezichtiging aan</span>
        </a>
      </div>

      <a href="{{ house.brochure }}" class="broker-download">
        <img
          src="/style/assets/download@2x.svg"
          alt=""
          class="broker-download-icon"
        >
        <span>Download brochure</span>
      </a>
    </aside>

  </div>

  <div class="success-toast" id="successToast">
    <div class="success-toast-bar"></div>
    <div class="success-toast-icon">✓</div>

    <div class="success-toast-content">
      <strong>Woning opgeslagen</strong>
      <p>Deze woning is toegevoegd aan je favorieten.</p>
    </div>

    <button type="button" class="success-toast-close">×</button>
  </div>

</main>

{% render 'partials/footer.liquid' %}