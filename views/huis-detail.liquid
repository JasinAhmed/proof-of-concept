{% render 'partials/head.liquid' %}
{% render 'partials/header.liquid' %}

<main class="house-detail">

  <section class="funda-gallery" aria-label="Foto's van de woning">
    <div class="gallery-large">
      <picture>
        <source srcset="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?format=avif&amp;width=1200" type="image/avif">
        <source srcset="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?format=webp&amp;width=1200" type="image/webp">
        <img src="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?width=1200" alt="{{ house.street }} {{ house.house_nr }}">
      </picture>
    </div>

    <div class="gallery-small">
      {% for image in house.gallery limit:4 %}
        <picture>
          <source srcset="https://fdnd-agency.directus.app/assets/{{ image.directus_files_id }}?format=avif&amp;width=600" type="image/avif">
          <source srcset="https://fdnd-agency.directus.app/assets/{{ image.directus_files_id }}?format=webp&amp;width=600" type="image/webp">
          <img src="https://fdnd-agency.directus.app/assets/{{ image.directus_files_id }}?width=600" alt="Foto van {{ house.street }} {{ house.house_nr }}">
        </picture>
      {% endfor %}

      <a href="#" class="all-photos-button">Bekijk alle foto's</a>
    </div>
  </section>

  <section class="media-bar" aria-label="Media opties">
    <a href="#">📷 Foto's</a>
    <a href="#">📐 Plattegrond</a>
    <a href="#">🏠 360° foto's</a>
    <a href="#">🎥 Video</a>
  </section>

  <div class="detail-wrapper">

    <article class="detail-main">

      <p class="breadcrumb">{{ house.city }} / {{ house.street }}</p>

      <header class="detail-header">
        <h1>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</h1>
        <p>{{ house.postal_code }} {{ house.city }}</p>
        <strong>€ {{ house.price }} k.k.</strong>
      </header>

      <section class="quick-info" aria-label="Belangrijkste kenmerken">
        <div>
          <span>🏠</span>
          <p><strong>{{ house.m2 }} m²</strong> wonen</p>
        </div>

        <div>
          <span>🌳</span>
          <p><strong>{{ house.m2_garden }} m²</strong> perceel</p>
        </div>

        <div>
          <span>🚪</span>
          <p><strong>{{ house.rooms }}</strong> kamers</p>
        </div>

        <div>
          <span>⚡</span>
          <p><strong>A</strong> energielabel</p>
        </div>
      </section>

      <section class="funda-action-row">
        <a href="#" class="monthly-button">Bereken je maandlasten</a>
        <a href="#" class="map-button">Bekijk op kaart</a>
      </section>

      <section class="description-section">
        <h2>Omschrijving</h2>
        <div class="description-text">
          {{ house.description }}
        </div>
      </section>

      <section class="popularity-card">
        <h2>Populariteit</h2>

        <div class="popularity-grid">
          <div>
            <strong>2.481x</strong>
            <span>Bekeken</span>
          </div>

          <div>
            <strong>47x</strong>
            <span>Bewaard</span>
          </div>

          <div>
            <strong>{{ house.listed_date }}</strong>
            <span>Aangeboden sinds</span>
          </div>
        </div>
      </section>

      <section class="save-house-card">
        <h2>Wil je dit huis niet vergeten?</h2>
        <p>Bewaar deze woning als favoriet zodat je hem later makkelijk terug kunt vinden.</p>
        <a href="#" class="save-button">♡ Bewaren</a>
      </section>

      <section class="features-section">
        <h2>Kenmerken</h2>

        <div class="feature-table">
          <h3>Overdracht</h3>
          <dl>
            <div>
              <dt>Vraagprijs</dt>
              <dd>€ {{ house.price }} k.k.</dd>
            </div>
            <div>
              <dt>Status</dt>
              <dd>Beschikbaar</dd>
            </div>
            <div>
              <dt>Aangeboden sinds</dt>
              <dd>{{ house.listed_date }}</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Adres</h3>
          <dl>
            <div>
              <dt>Straat</dt>
              <dd>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</dd>
            </div>
            <div>
              <dt>Postcode</dt>
              <dd>{{ house.postal_code }}</dd>
            </div>
            <div>
              <dt>Plaats</dt>
              <dd>{{ house.city }}</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Bouw</h3>
          <dl>
            <div>
              <dt>Soort woning</dt>
              <dd>Woonhuis</dd>
            </div>
            <div>
              <dt>Bouwjaar</dt>
              <dd>2020</dd>
            </div>
            <div>
              <dt>Soort bouw</dt>
              <dd>Bestaande bouw</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Oppervlakten en inhoud</h3>
          <dl>
            <div>
              <dt>Wonen</dt>
              <dd>{{ house.m2 }} m²</dd>
            </div>
            <div>
              <dt>Perceel</dt>
              <dd>{{ house.m2_garden }} m²</dd>
            </div>
            <div>
              <dt>Inhoud</dt>
              <dd>320 m³</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Indeling</h3>
          <dl>
            <div>
              <dt>Aantal kamers</dt>
              <dd>{{ house.rooms }}</dd>
            </div>
            <div>
              <dt>Aantal slaapkamers</dt>
              <dd>2</dd>
            </div>
            <div>
              <dt>Aantal badkamers</dt>
              <dd>1</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Energie</h3>
          <dl>
            <div>
              <dt>Energielabel</dt>
              <dd>A</dd>
            </div>
            <div>
              <dt>Isolatie</dt>
              <dd>Volledig geïsoleerd</dd>
            </div>
            <div>
              <dt>Verwarming</dt>
              <dd>Centrale verwarming</dd>
            </div>
          </dl>
        </div>

        <div class="feature-table">
          <h3>Buitenruimte</h3>
          <dl>
            <div>
              <dt>Tuin</dt>
              <dd>{{ house.m2_garden }} m²</dd>
            </div>
            <div>
              <dt>Ligging</dt>
              <dd>Aan rustige straat</dd>
            </div>
          </dl>
        </div>
      </section>

    </article>

    <aside class="agent-card">
      <div class="agent-logo">funda</div>

      <h2>Interesse in deze woning?</h2>
      <p>Aangeboden door {{ house.agent }}. Neem contact op met de makelaar of plan direct een bezichtiging.</p>

      <a href="#" class="primary-button">Plan een bezichtiging</a>
      <a href="#" class="secondary-button">Stuur bericht</a>
      <a href="#" class="phone-button">Bel de makelaar</a>
      <a href="#" class="brochure-button">Download brochure</a>
    </aside>

  </div>

</main>

{% render 'partials/footer.liquid' %}