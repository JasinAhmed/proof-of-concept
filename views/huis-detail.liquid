{% render 'partials/head.liquid' %}
{% render 'partials/header.liquid' %}

<main class="house-detail">

  <nav class="detail-breadcrumb">
    <a href="/">⌂</a>
    <span>/</span>
    <a href="#">{{ house.city }}</a>
    <span>/</span>
    <a href="#">{{ house.city }} Plassengebied</a>
    <span>/</span>
    <span>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</span>
  </nav>

  <section class="funda-gallery">

    <div class="gallery-main">
      <img
        src="https://fdnd-agency.directus.app/assets/{{ house.poster_image.id }}?width=1400"
        alt="{{ house.street }}"
      >
    </div>

    <div class="gallery-side">
      {% for image in house.gallery limit:4 %}
        <div class="gallery-tile">
          <img
            src="https://fdnd-agency.directus.app/assets/{{ image.directus_files_id }}?width=900"
            alt="Foto van {{ house.street }}"
          >
        </div>
      {% endfor %}
    </div>

    <div class="gallery-actions">
      <a href="#" class="gallery-btn">Delen</a>

      <form action="/favorieten/{{ house.id }}" method="POST">
        <button type="submit" class="gallery-btn">♡ Bewaar</button>
      </form>
    </div>

  </section>

  <nav class="media-bar">
    <a href="#">▣ Foto's <span>77</span></a>
    <a href="#">▱ Plattegrond <span>7</span></a>
    <a href="#">▷ Video</a>
    <a href="#">▦ Alle media</a>
  </nav>

  <div class="detail-wrapper">

    <article class="detail-main">

      <header class="detail-header">
        <h1>{{ house.street }} {{ house.house_nr }}{{ house.nr_addition }}</h1>

        <p>{{ house.postal_code }} {{ house.city }}</p>

        <a href="#" class="area-link">
          {{ house.city }} Plassengebied
        </a>

        <strong>€ {{ house.price }} k.k.</strong>
      </header>

      <section class="quick-info">
        <div>
          <span>⌂</span>
          <p><strong>{{ house.m2 }} m²</strong> wonen</p>
        </div>

        <div>
          <span>▧</span>
          <p><strong>{{ house.m2_garden }} m²</strong> perceel</p>
        </div>

        <div>
          <span>▤</span>
          <p><strong>{{ house.rooms }}</strong> kamers</p>
        </div>
      </section>

      <section class="funda-action-row">
        <a href="#" class="monthly-button">Wat worden mijn maandlasten?</a>
        <a href="#" class="map-button">Bekijk op kaart</a>
      </section>

      <section class="description-section">
        <h2>Omschrijving</h2>

        <div class="description-text">
          {{ house.description }}
        </div>

        <a href="#" class="read-more">
          Lees de volledige omschrijving
        </a>
      </section>

      <section class="features-section">
        <h2>Kenmerken</h2>

        <div class="features-card">

          <div class="feature-group">
            <div class="feature-group__title">
              <span>🤝</span>
              <h3>Overdracht</h3>
            </div>

            <dl>
              <div>
                <dt>Aangeboden sinds</dt>
                <dd><a href="#">Log in om te bekijken</a></dd>
              </div>

              <div>
                <dt>Aanvaarding</dt>
                <dd>In overleg</dd>
              </div>

              <div>
                <dt>Vraagprijs</dt>
                <dd>€ {{ house.price }} kosten koper</dd>
              </div>

              <div>
                <dt>Status</dt>
                <dd>Beschikbaar</dd>
              </div>
            </dl>
          </div>

          <div class="feature-group">
            <div class="feature-group__title">
              <span>🏗️</span>
              <h3>Bouw</h3>
            </div>

            <dl>
              <div>
                <dt>Soort woning</dt>
                <dd>Villa, vrijstaande woning</dd>
              </div>

              <div>
                <dt>Soort bouw</dt>
                <dd>Bestaande bouw</dd>
              </div>

              <div>
                <dt>Bouwjaar</dt>
                <dd>2017</dd>
              </div>

              <div>
                <dt>Soort dak</dt>
                <dd>Mansarde dak</dd>
              </div>
            </dl>
          </div>

          <div class="feature-group">
            <div class="feature-group__title">
              <span>📐</span>
              <h3>Oppervlakten en inhoud</h3>
            </div>

            <dl>
              <div>
                <dt>Wonen</dt>
                <dd>{{ house.m2 }} m²</dd>
              </div>

              <div>
                <dt>Perceel</dt>
                <dd>{{ house.m2_garden }} m²</dd>
              </div>

              <div>
                <dt>Gebouwgebonden buitenruimte</dt>
                <dd>150 m²</dd>
              </div>

              <div>
                <dt>Externe bergruimte</dt>
                <dd>17 m²</dd>
              </div>

              <div>
                <dt>Inhoud</dt>
                <dd>4.300 m³</dd>
              </div>
            </dl>
          </div>

          <div class="feature-group">
            <div class="feature-group__title">
              <span>🏠</span>
              <h3>Indeling</h3>
            </div>

            <dl>
              <div>
                <dt>Aantal kamers</dt>
                <dd>{{ house.rooms }} kamers</dd>
              </div>

              <div>
                <dt>Aantal slaapkamers</dt>
                <dd>7 slaapkamers</dd>
              </div>

              <div>
                <dt>Aantal badkamers</dt>
                <dd>8 badkamers</dd>
              </div>

              <div>
                <dt>Aantal woonlagen</dt>
                <dd>3 woonlagen</dd>
              </div>
            </dl>
          </div>

        </div>
      </section>

      <section class="popularity-section">
        <div class="section-header">
          <h2>Populariteit</h2>
          <a href="#">Log in om te bekijken</a>
        </div>

        <div class="popularity-card">
          <div class="popularity-item">
            <span>👁</span>
            <strong>226.318x</strong>
            <p>Bekeken</p>
          </div>

          <div class="popularity-item">
            <span>♡</span>
            <strong>1.889x</strong>
            <p>Bewaard</p>
          </div>

          <div class="popularity-item">
            <span>📅</span>
            <strong>6-8-2025</strong>
            <p>Op Funda</p>
          </div>
        </div>
      </section>

      <section class="neighborhood-section">
        <h2>Buurt</h2>

        <div class="neighborhood-layout">

          <div class="neighborhood-card">

            <div class="neighborhood-header">
              <div class="neighborhood-icon">
                📍
              </div>

              <div>
                <h3>{{ house.city }} Plassengebied</h3>
                <p>{{ house.city }}</p>
              </div>
            </div>

            <dl>
              <div>
                <dt>Inwoners</dt>
                <dd>1.880</dd>
              </div>

              <div>
                <dt>Gezin met kinderen</dt>
                <dd>26%</dd>
              </div>

              <div>
                <dt>Gem. vraagprijs / m²</dt>
                <dd>€ 8.078</dd>
              </div>
            </dl>

          </div>

          <div class="neighborhood-discover">
            <h3>Ontdek de buurt</h3>

            <p>
              Benieuwd naar het woningaanbod, bewoners en lokale makelaars?
            </p>

            <a href="#">
              Bekijk buurtinzichten →
            </a>
          </div>

        </div>
      </section>

    </article>

    <aside class="agent-card">
      <div class="agent-logo">
        funda
      </div>

      <h2>Interesse in deze woning?</h2>

      <p>
        Aangeboden door <strong>{{ house.agent }}</strong>.
        Neem contact op met de makelaar of plan direct een bezichtiging.
      </p>

      <a href="#" class="primary-button">Plan een bezichtiging</a>
      <a href="#" class="secondary-button">Stuur bericht</a>
      <a href="#" class="phone-button">Bel de makelaar</a>
    </aside>

  </div>

</main>

{% render 'partials/footer.liquid' %}